# ╔══════════════════════════════════════════════════════════════════╗
# ║                      公共配置（所有技能共用）                       ║
# ╚══════════════════════════════════════════════════════════════════╝

# 钉钉应用凭证（开放平台 → 应用管理 → 凭证信息）
DINGTALK_APP_KEY=your_app_key_here
DINGTALK_APP_SECRET=your_app_secret_here

# 企业 corpId（开放平台 → 应用管理 → 基本信息）
DINGTALK_CORP_ID=your_corp_id_here

# 操作者 unionId（开发者后台 → 调试工具 → 获取 unionId）
OPERATOR_ID=your_union_id_here

# 写入测试开关（默认关闭，设置为 1 启用覆写文档/表格等破坏性测试）
ENABLE_WRITE_TESTS=0

# ╔══════════════════════════════════════════════════════════════════╗
# ║                 dingtalk-document 知识库 & 文档                    ║
# ╚══════════════════════════════════════════════════════════════════╝

# 测试用文档节点 ID（从 alidocs URL 提取：/nodes/<nodeId>）
TEST_NODE_ID=your_node_id_here

# 测试用文档完整 URL
TEST_NODE_URL=https://alidocs.dingtalk.com/i/nodes/your_node_id_here

# 创建/删除临时文档时使用的知识库 workspaceId
TEST_WORKSPACE_ID=your_workspace_id_here

# ╔══════════════════════════════════════════════════════════════════╗
# ║                   dingtalk-ai-table AI 表格                       ║
# ╚══════════════════════════════════════════════════════════════════╝

# AI 表格（.able 文件）的 nodeId
# 从分享链接提取：https://alidocs.dingtalk.com/i/nodes/<nodeId>
TEST_NOTABLE_ID=your_notable_id_here

# 普通电子表格 workbookId（.xlsx / SHEET 类型，非 .able）
# 若留空，测试框架会在 TEST_WORKSPACE_ID 下自动创建临时工作簿并在结束后删除
TEST_WORKBOOK_ID=

# ╔══════════════════════════════════════════════════════════════════╗
# ║                   dingtalk-message 消息发送                       ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Webhook 机器人（群设置 → 智能群助手 → 自定义机器人）──────────
# 完整 Webhook URL（含 access_token）
TEST_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=your_token_here
# 加签密钥（选填，不配置则跳过加签测试）
TEST_WEBHOOK_SECRET=

# ── 企业内部应用机器人 ──────────────────────────────────────────
# 机器人 robotCode（通常等于 DINGTALK_APP_KEY）
TEST_ROBOT_CODE=your_robot_code_here
# 测试目标用户 userId（机器人单聊消息的接收人）
TEST_USER_ID=your_user_id_here
# 测试群的 openConversationId（机器人群聊消息用）
# 可通过机器人收到群消息回调时获得，或调用 IM 接口创建群时返回
TEST_OPEN_CONVERSATION_ID=your_open_conversation_id_here

# ── 工作通知 ────────────────────────────────────────────────────
# 应用 agentId（开放平台 → 应用管理 → 基本信息）
TEST_AGENT_ID=your_agent_id_here
